{
  "name": "@loadout/plugin-apex-fixes",
  "version": "0.0.1",
  "type": "module",
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-icons": "^5.6.0",
    "@loadout/ui": "workspace:*",
    "@loadout/types": "workspace:*",
    "@loadout/exec": "workspace:*"
  },
  "plugin": {
    "id": "apex-fixes",
    "name": "Apex Fixes",
    "description": "Device-specific workarounds for the OneXPlayer Apex — oxpec EC sensor driver (fan detection), sleep/wake fixes, and gamepad USB recovery.",
    "permissions": {
      "commands": ["modprobe", "insmod", "rmmod", "systemctl", "rpm-ostree", "ostree", "udevadm", "lsusb", "tee", "mkdir", "rm", "chmod", "cp", "test", "chcon"],
      "filesystem": ["/sys/class/dmi", "/sys/class/hwmon", "/etc/systemd/system", "/etc/udev/rules.d", "/usr/lib/systemd/system-sleep", "/usr/local/sbin", "/sys/bus/pci"]
    },
    "category": "Device",
    "subtitle": "OneXPlayer Apex fan + sleep fixes",
    "target": { "type": "overlay" }
  }
}
