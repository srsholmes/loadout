{
  "name": "@loadout/plugin-quick-links",
  "version": "0.0.1",
  "type": "module",
  "description": "Open contextual links (wiki, ProtonDB, YouTube guides, …) for the currently playing game",
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "@loadout/ui": "workspace:*",
    "@loadout/types": "workspace:*",
    "@loadout/exec": "workspace:*",
    "@loadout/plugin-storage": "workspace:*",
    "@loadout/steam-cdp": "workspace:*",
    "@loadout/steam-paths": "workspace:*",
    "@loadout/vdf": "workspace:*"
  },
  "plugin": {
    "id": "quick-links",
    "name": "Quick Links",
    "description": "Open YouTube guides, ProtonDB, wikis and more for the game you're playing",
    "category": "Game",
    "subtitle": "Per-game contextual links",
    "target": { "type": "overlay" },
    "permissions": {
      "commands": [
        "which",
        "flatpak",
        "systemctl",
        "pgrep",
        "xprop",
        "firefox",
        "google-chrome-stable",
        "google-chrome",
        "brave-browser",
        "brave",
        "chromium",
        "chromium-browser",
        "microsoft-edge-stable",
        "microsoft-edge",
        "vivaldi",
        "vivaldi-stable"
      ],
      "filesystem": [
        "/sys/class/drm",
        "~/.local/share/Steam/userdata"
      ],
      "network": ["localhost", "127.0.0.1"]
    }
  }
}
