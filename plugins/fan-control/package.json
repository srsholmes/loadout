{
  "name": "@loadout/plugin-fan-control",
  "version": "0.0.1",
  "type": "module",
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-icons": "^5.6.0",
    "@loadout/ui": "workspace:*",
    "@loadout/types": "workspace:*",
    "@loadout/exec": "workspace:*"
  },
  "plugin": {
    "id": "fan-control",
    "name": "Fan Control",
    "description": "Monitor and control fan speed, temperature, and fan curve presets",
    "permissions": {
      "commands": ["ectool", "tee"]
    },
    "category": "Performance",
    "subtitle": "Fan speed + thermal profiles"
  }
}
