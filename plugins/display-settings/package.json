{
  "name": "@loadout/plugin-display-settings",
  "version": "0.0.1",
  "type": "module",
  "dependencies": {
    "react": "^18.3.0",
    "@loadout/ui": "workspace:*",
    "@loadout/types": "workspace:*",
    "@loadout/exec": "workspace:*"
  },
  "plugin": {
    "id": "display-settings",
    "name": "Display Settings",
    "description": "Adjust display brightness and saturation",
    "permissions": {
      "commands": ["xprop", "busctl", "setpriv"],
      "filesystem": ["/sys/class/backlight"]
    },
    "category": "Device",
    "subtitle": "Brightness + saturation",
    "target": { "type": "overlay" }
  }
}
