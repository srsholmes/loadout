{
  "name": "@loadout/plugin-tdp-control",
  "version": "0.0.1",
  "type": "module",
  "description": "TDP (Thermal Design Power) control for Linux handhelds — adjust wattage via ryzenadj or sysfs",
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-icons": "^5.6.0",
    "@loadout/ui": "workspace:*",
    "@loadout/types": "workspace:*",
    "@loadout/exec": "workspace:*",
    "@loadout/steam-paths": "workspace:*"
  },
  "plugin": {
    "id": "tdp-control",
    "name": "TDP Control",
    "description": "Adjust CPU/APU TDP wattage with presets and a slider",
    "permissions": {
      "commands": ["ryzenadj", "tee"],
      "filesystem": [
        "/sys/devices/system/cpu",
        "/sys/devices/virtual/powercap",
        "/sys/class/powercap",
        "/sys/firmware/acpi",
        "/sys/class/drm",
        "/sys/class/power_supply",
        "/sys/devices/platform",
        "/sys/class/firmware-attributes"
      ]
    },
    "category": "Performance",
    "subtitle": "CPU/GPU power limits"
  }
}
