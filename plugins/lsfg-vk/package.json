{
  "name": "@loadout/plugin-lsfg-vk",
  "private": true,
  "version": "1.0.0",
  "description": "Configure Vulkan frame generation (LSFG-VK) layer",
  "author": "Loadout",
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "@loadout/ui": "workspace:*",
    "@loadout/exec": "workspace:*"
  },
  "plugin": {
    "id": "lsfg-vk",
    "name": "LSFG-VK",
    "description": "Install and configure the LSFG-VK Vulkan frame generation layer",
    "category": "Performance",
    "subtitle": "Vulkan frame generation",
    "permissions": {
      "network": [
        "api.github.com",
        "github.com",
        "objects.githubusercontent.com"
      ],
      "filesystem": [
        "~/.local/lib",
        "~/.local/share/vulkan/implicit_layer.d",
        "~/.config/lsfg-vk",
        "~/lsfg",
        "~/.config/loadout/lsfg-vk",
        "~/.local/share/Steam/steamapps/common/Lossless Scaling"
      ],
      "system": [
        "exec"
      ]
    }
  }
}
